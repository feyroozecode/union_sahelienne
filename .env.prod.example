# ── App ──────────────────────────────────────────────
NODE_ENV=production
APP_PORT=3000
APP_NAME="Union Sahelienne API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=https://union-sahel.alfajarsoft.com
BACKEND_DOMAIN=https://api-unionsahel.alfajarsoft.com

# ── Database ─────────────────────────────────────────
DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=us_admin
DATABASE_PASSWORD=<generate-strong-password>
DATABASE_NAME=union_sahelienne
DATABASE_MAX_CONNECTIONS=50
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_URL=postgresql://us_admin:<password>@postgres:5432/union_sahelienne

# ── File Storage ─────────────────────────────────────
FILE_DRIVER=local
# For S3:
# FILE_DRIVER=s3
# ACCESS_KEY_ID=
# SECRET_ACCESS_KEY=
# AWS_S3_REGION=
# AWS_DEFAULT_S3_BUCKET=

# ── Mail (SMTP) ──────────────────────────────────────
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USER=apikey
MAIL_PASSWORD=<sendgrid-api-key>
MAIL_IGNORE_TLS=false
MAIL_SECURE=false
MAIL_REQUIRE_TLS=true
MAIL_DEFAULT_EMAIL=noreply@alfajarsoft.com
MAIL_DEFAULT_NAME="Union Sahelienne"

# ── Auth Secrets (REPLACE ALL WITH STRONG RANDOM VALUES) ──
AUTH_JWT_SECRET=<random-64-chars>
AUTH_JWT_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=<random-64-chars>
AUTH_REFRESH_TOKEN_EXPIRES_IN=3650d
AUTH_FORGOT_SECRET=<random-64-chars>
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m
AUTH_CONFIRM_EMAIL_SECRET=<random-64-chars>
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

# ── Social Auth ──────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_APP_AUDIENCE=[]

# ── Admin Frontend ───────────────────────────────────
NEXT_PUBLIC_API_URL=https://api-unionsahel.alfajarsoft.com/api/v1
