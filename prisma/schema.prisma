generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int    @id
  name  String
  users User[]

  @@map("role")
}

model Status {
  id    Int    @id
  name  String
  users User[]

  @@map("status")
}

model File {
  id   String @id @default(uuid()) @db.Uuid
  path String
  user User?

  @@map("file")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String?   @unique
  password  String?
  provider  String    @default("email")
  socialId  String?
  firstName String?
  lastName  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  photo   File?   @relation(fields: [photoId], references: [id])
  photoId String? @unique @db.Uuid

  role   Role? @relation(fields: [roleId], references: [id])
  roleId Int?

  status   Status? @relation(fields: [statusId], references: [id])
  statusId Int?

  sessions Session[]

  @@index([socialId])
  @@index([firstName])
  @@index([lastName])
  @@map("user")
}

model Session {
  id        Int       @id @default(autoincrement())
  hash      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user   User @relation(fields: [userId], references: [id])
  userId Int

  @@index([userId])
  @@map("session")
}
