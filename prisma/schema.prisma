generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int    @id
  name  String
  users User[]

  @@map("role")
}

model Status {
  id    Int    @id
  name  String
  users User[]

  @@map("status")
}

model File {
  id   String @id @default(uuid()) @db.Uuid
  path String
  user User?

  @@map("file")
}

model User {
  id          Int       @id @default(autoincrement())
  email       String?   @unique
  phone       String?   @unique
  password    String?
  provider    String    @default("email")
  socialId    String?
  firstName   String?
  lastName    String?
  otpHash     String?
  otpExpiry   DateTime?
  otpPurpose  String?
  lastOtpAt   DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  photo   File?   @relation(fields: [photoId], references: [id])
  photoId String? @unique @db.Uuid

  role   Role? @relation(fields: [roleId], references: [id])
  roleId Int?

  status   Status? @relation(fields: [statusId], references: [id])
  statusId Int?

  sessions         Session[]
  profile          Profile?
  payments         Payment[]
  requestedMatches Match[]        @relation("MatchRequester")
  targetedMatches  Match[]        @relation("MatchTarget")
  subscriptions    Subscription[]
  sentMessages     Message[]      @relation("SentMessages")
  filedReports     Report[]       @relation("FiledReports")
  receivedReports  Report[]       @relation("ReceivedReports")

  @@index([socialId])
  @@index([firstName])
  @@index([lastName])
  @@map("user")
}

model Session {
  id        Int       @id @default(autoincrement())
  hash      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user   User @relation(fields: [userId], references: [id])
  userId Int

  @@index([userId])
  @@map("session")
}

model Profile {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique
  user             User      @relation(fields: [userId], references: [id])
  gender           String    @default("unspecified")
  age              Int?
  profession       String?
  maritalStatus    String?
  childrenCount    Int?
  ethnicity        String?
  country          String?
  city             String?
  bloodType        String?
  hivTest          Boolean?
  hepatitisTest    Boolean?
  searchedAgeMin   Int?
  searchedAgeMax   Int?
  searchedMarital  String?
  searchedCriteria String?
  termsAcceptedAt     DateTime?
  isComplete          Boolean   @default(false)
  isValidated         Boolean   @default(false)

  identityDocType     String?
  identityDocPath     String?
  isIdentityVerified  Boolean   @default(false)

  subscriptionType    String?
  matchCreditsTotal   Int       @default(0)
  matchCreditsUsed    Int       @default(0)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("profile")
}

model Payment {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  type        String
  status      String    @default("pending")
  receiptPath String?
  waveRef     String?   @unique
  amount      Float?
  validatedAt DateTime?
  validatedBy Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@map("payment")
}

model Match {
  id            Int       @id @default(autoincrement())
  requesterId   Int
  requester     User      @relation("MatchRequester", fields: [requesterId], references: [id])
  targetId      Int
  target        User      @relation("MatchTarget", fields: [targetId], references: [id])
  pairKey       String    @unique
  status        String    @default("pending")
  chatOpenedAt  DateTime?
  chatExpiresAt DateTime?
  cooldownUntil DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages Message[]

  @@index([requesterId])
  @@index([targetId])
  @@map("match")
}

model Subscription {
  id               Int       @id @default(autoincrement())
  userId           Int
  user             User      @relation(fields: [userId], references: [id])
  tier             String
  creditsGranted   Int
  creditsBonus     Int       @default(0)
  creditsUsed      Int       @default(0)
  status           String    @default("active")
  expiresAt        DateTime?
  bonusExpiresAt   DateTime?
  paymentId        Int?      @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@map("subscription")
}

model Message {
  id        Int      @id @default(autoincrement())
  matchId   Int
  match     Match    @relation(fields: [matchId], references: [id])
  senderId  Int
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  content   String?  @db.Text
  imageUrl  String?
  sentAt    DateTime @default(now())

  @@index([matchId])
  @@index([senderId])
  @@map("message")
}

model Report {
  id          Int       @id @default(autoincrement())
  reporterId  Int
  reporter    User      @relation("FiledReports", fields: [reporterId], references: [id])
  targetId    Int
  target      User      @relation("ReceivedReports", fields: [targetId], references: [id])
  type        String
  description String?   @db.Text
  status      String    @default("pending")
  reviewedBy  Int?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([reporterId])
  @@index([targetId])
  @@map("report")
}
